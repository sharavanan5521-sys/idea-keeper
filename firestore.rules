rules_version = '2';

/**
 * Keep in sync with the Firebase console / deployed rules.
 * Deploy: firebase deploy --only firestore:rules
 */
service cloud.firestore {
  match /databases/{database}/documents {

    match /ideas/{ideaId} {
      // Read/delete only if this idea belongs to the signed-in user
      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Create: incoming doc must claim the same uid as the signed-in user
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Update only if the existing doc belongs to this user
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
